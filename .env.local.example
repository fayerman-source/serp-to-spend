# Pick ONE provider. The app auto-detects: LLM_PROVIDER wins; else Gemini if
# GOOGLE_CLOUD_PROJECT is set; else Claude.

# --- Option A: Gemini on Vertex AI (bills your Google Cloud credit) ---
LLM_PROVIDER=gemini
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash          # gemini-2.5-pro for higher quality
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Option B: first-party Anthropic (Anthropic credit balance) ---
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-opus-4-8

# --- Option C: Claude on Vertex (needs Claude enabled + quota in Model Garden) ---
# LLM_PROVIDER=claude
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
# CLOUD_ML_REGION=global
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional: SerpApi key for real organic-SERP grounding on keyword input.
# Without it, keyword input is generated from the model's own knowledge and
# URL input is grounded by fetching the page directly.
SERPAPI_KEY=
